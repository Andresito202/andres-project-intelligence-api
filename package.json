{
  "name": "andres-project-intelligence-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Professional portfolio API for Andres Camacho projects, case studies, skills, repository status, and contact messages.",
  "scripts": {
    "dev": "wrangler dev --local --persist-to .wrangler/state --port 8787",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run lint && npm run typecheck && npm run test",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply portfolio_api --local",
    "db:migrate:remote": "wrangler d1 migrations apply portfolio_api --remote",
    "db:seed:local": "wrangler d1 execute portfolio_api --local --file=./src/db/seed.sql",
    "db:seed:remote": "wrangler d1 execute portfolio_api --remote --file=./src/db/seed.sql"
  },
  "keywords": [
    "cloudflare-workers",
    "hono",
    "d1",
    "drizzle",
    "portfolio-api",
    "typescript"
  ],
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-validator": "^0.7.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.10.6",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.3",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.0.14",
    "wrangler": "^4.50.0"
  },
  "engines": {
    "node": ">=22"
  }
}
